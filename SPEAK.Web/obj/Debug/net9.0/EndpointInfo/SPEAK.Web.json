    "/api/MergeVoices/merge-voices": {
      "post": {
        "tags": [
          "MergeVoices"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "files": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "type": {
                    "type": "string",
                    "default": "general"
                  }
                }
              },
              "encoding": {
                "files": {
                  "style": "form"
                },
                "type": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/MergeVoices/cleanup-merged": {
