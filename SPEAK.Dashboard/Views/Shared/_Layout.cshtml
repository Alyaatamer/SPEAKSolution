<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Medical Admin - @ViewData["Title"]</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f5f6fa;
            color: #333;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ─── SIDEBAR ─── */
        .sidebar {
            width: 200px;
            background: #fff;
            border-right: 1px solid #e8eaf0;
            display: flex;
            flex-direction: column;
            padding: 20px 0;
            flex-shrink: 0;
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 0 20px 24px 20px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: #1a56db;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
        }

        .logo-text {
            font-size: 14px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .sidebar-nav {
            flex: 1;
            padding: 0 12px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #64748b;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            transition: all 0.2s;
            margin-bottom: 2px;
        }

        .nav-item:hover {
            background: #f1f5f9;
            color: #1a56db;
        }

        .nav-item.active {
            background: #1a56db;
            color: #fff;
        }

        .nav-item svg { flex-shrink: 0; }

        .sidebar-footer {
            padding: 12px;
            border-top: 1px solid #f1f5f9;
            margin-top: 8px;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 8px;
            color: #e53e3e;
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 500;
            cursor: pointer;
            border: none;
            background: none;
            width: 100%;
            transition: background 0.2s;
        }

        .logout-btn:hover { background: #fff5f5; }

        /* ─── MAIN AREA ─── */
        .main-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* ─── TOPBAR ─── */
        .topbar {
            height: 56px;
            background: #fff;
            border-bottom: 1px solid #e8eaf0;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 28px;
            flex-shrink: 0;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            padding: 6px 10px;
            border-radius: 8px;
            transition: background 0.2s;
        }

        .user-chip:hover { background: #f1f5f9; }

        .user-avatar {
            width: 34px;
            height: 34px;
            background: #1a56db;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .user-info { text-align: right; }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: #1a1a2e;
        }

        .user-role {
            font-size: 11px;
            color: #94a3b8;
        }

        /* ─── PAGE CONTENT ─── */
        .page-content {
            flex: 1;
            overflow-y: auto;
            padding: 28px 32px;
        }

        /* ─── BADGE STYLES ─── */
        .badge {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        .badge-pending  { background: #fff7e6; color: #d97706; border: 1px solid #fcd34d; }
        .badge-approved { background: #ecfdf5; color: #059669; border: 1px solid #6ee7b7; }
        .badge-rejected { background: #fef2f2; color: #dc2626; border: 1px solid #fca5a5; }
        .badge-active   { background: #ecfdf5; color: #059669; border: 1px solid #6ee7b7; }
        .badge-disabled { background: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; }

        /* ─── CARD ─── */
        .card {
            background: #fff;
            border-radius: 12px;
            border: 1px solid #e8eaf0;
            padding: 20px;
        }

        /* ─── BUTTONS ─── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: opacity 0.2s;
        }
        .btn:hover { opacity: 0.85; }
        .btn-approve { background: #1a56db; color: #fff; }
        .btn-reject  { background: #e53e3e; color: #fff; }
        .btn-disable { background: #f59e0b; color: #fff; }
        .btn-activate{ background: #10b981; color: #fff; }
        .btn-delete  { background: #ef4444; color: #fff; }

        /* ─── TABLE ─── */
        .data-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13.5px;
        }

        .data-table th {
            text-align: left;
            padding: 10px 14px;
            color: #64748b;
            font-weight: 600;
            font-size: 12.5px;
            border-bottom: 1px solid #f1f5f9;
        }

        .data-table td {
            padding: 13px 14px;
            border-bottom: 1px solid #f9fafb;
            vertical-align: middle;
        }

        .data-table tr:last-child td { border-bottom: none; }
        .data-table tr:hover td { background: #fafbfc; }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">e</div>
            <span class="logo-text">SPEAK</span>
        </div>

        <nav class="sidebar-nav">
            <a href="/Home/Index"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <!-- Dashboard icon -->
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                </svg>
                Dashboard
            </a>

            <a href="/DoctorVerification"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "DoctorVerification" ? "active" : "")">
                <!-- Doctor icon -->
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
                Doctor Verification
            </a>

            <a href="/UserManagement"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "UserManagement" ? "active" : "")">
                <!-- Users icon -->
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                User Management
            </a>

            <a href="/AdminLogs"
               class="nav-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminLogs" ? "active" : "")">
                <!-- Logs icon -->
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                </svg>
                Admin Logs
            </a>
        </nav>

        <div class="sidebar-footer">
            <form method="post" action="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                    Logout
                </button>
            </form>
        </div>
    </aside>

    <!-- MAIN -->
    <div class="main-wrapper">
        <!-- TOPBAR -->
        <header class="topbar">
            <div class="user-chip">
                <div class="user-info">
                    <div class="user-name">@(User.Identity?.Name ?? "Admin User")</div>
                    <div class="user-role">Administrator</div>
                </div>
                <div class="user-avatar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </div>
            </div>
        </header>

        <!-- PAGE CONTENT -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
