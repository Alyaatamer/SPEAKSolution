@model SPEAK.Dashboard.ViewModels.DoctorVerificationViewModel
@{
    ViewData["Title"] = "Doctor Verification";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:22px;">
    <h2 style="font-size:20px; font-weight:700; color:#1a1a2e;">Doctor Verification</h2>

    <!-- Filter Dropdown -->
    <form method="get" action="/DoctorVerification" style="display:flex; align-items:center; gap:8px;">
        <label style="font-size:13px; color:#64748b; font-weight:500;">Filter:</label>
        <select name="statusFilter" onchange="this.form.submit()"
                style="border:1px solid #e2e8f0; border-radius:6px; padding:6px 12px; font-size:13px; color:#1a1a2e; cursor:pointer; background:#fff;">
            <option value="All"      selected="@(Model.StatusFilter == "All"      ? "selected" : null)">All</option>
            <option value="Pending"  selected="@(Model.StatusFilter == "Pending"  ? "selected" : null)">Pending</option>
            <option value="Approved" selected="@(Model.StatusFilter == "Approved" ? "selected" : null)">Approved</option>
            <option value="Rejected" selected="@(Model.StatusFilter == "Rejected" ? "selected" : null)">Rejected</option>
        </select>
    </form>
</div>

<div class="card" style="padding:0; overflow:hidden;">
    <table class="data-table">
        <thead style="background:#fafbfc;">
            <tr>
                <th>Doctor Name</th>
                <th>Syndicate Number</th>
                <th>Documents</th>
                <th>Registration Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doctor in Model.Doctors)
            {
                <tr>
                    <td style="font-weight:500; color:#1a1a2e;">@doctor.DisplayName</td>
                    <td style="color:#64748b;">@doctor.Email</td>

                    <!-- Documents links -->
                    <td>
                        @if (!string.IsNullOrEmpty(doctor.NationalIdImageUrl))
                        {
                            <a href="@doctor.NationalIdImageUrl" target="_blank"
                               style="color:#1a56db; text-decoration:none; font-size:13px; margin-right:10px;">
                                👁 National ID
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(doctor.SyndicateCardImageUrl))
                        {
                            <a href="@doctor.SyndicateCardImageUrl" target="_blank"
                               style="color:#1a56db; text-decoration:none; font-size:13px;">
                                👁 Syndicate Card
                            </a>
                        }
                    </td>

                    <td style="color:#64748b;">
                        @(doctor.ApprovedAt.HasValue ? doctor.ApprovedAt.Value.ToString("yyyy-MM-dd") : "—")
                    </td>

                    <!-- Status badge -->
                    <td>
                        @{
                            var badgeClass = doctor.DoctorStatus?.ToLower() switch
                            {
                                "approved" => "badge-approved",
                                "rejected" => "badge-rejected",
                                _ => "badge-pending"
                            };
                        }
                        <span class="badge @badgeClass">@doctor.DoctorStatus</span>
                    </td>

                    <!-- Actions -->
                    <td>
                        @if (doctor.DoctorStatus?.ToLower() == "pending")
                        {
                            <form method="post" action="/DoctorVerification/Approve" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="doctorUserId" value="@doctor.UserId" />
                                <button type="submit" class="btn btn-approve">✓ Approve</button>
                            </form>

                            <form method="post" action="/DoctorVerification/Reject" style="display:inline; margin-left:6px;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="doctorUserId" value="@doctor.UserId" />
                                <button type="submit" class="btn btn-reject">✕ Reject</button>
                            </form>
                        }
                        else
                        {
                            <span style="font-size:13px; color:#94a3b8;">No actions available</span>
                        }
                    </td>
                </tr>
            }

            @if (!Model.Doctors.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; padding:30px; color:#94a3b8;">No doctors found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
