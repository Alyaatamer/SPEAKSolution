@model SPEAK.Dashboard.ViewModels.UserManagementViewModel
@{
    ViewData["Title"] = "User Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 style="font-size:20px; font-weight:700; margin-bottom:22px; color:#1a1a2e;">User Management</h2>

<div class="card" style="padding:0; overflow:hidden;">
    <table class="data-table">
        <thead style="background:#fafbfc;">
            <tr>
                <th>User Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td style="font-weight:500; color:#1a1a2e;">@user.UserName</td>
                    <td style="color:#1a56db;">@user.Email</td>

                    <!-- Role dropdown (display only) -->
                    <td>
                        <span style="background:#f1f5f9; color:#475569; padding:4px 10px; border-radius:5px; font-size:13px; font-weight:500;">
                            @user.Role
                        </span>
                    </td>

                    <!-- Status badge -->
                    <td>
                        @if (user.Status == "Active")
                        {
                            <span class="badge badge-active">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-disabled">Disabled</span>
                        }
                    </td>

                    <td style="color:#64748b;">@user.CreatedAt.ToString("yyyy-MM-dd")</td>

                    <!-- Actions -->
                    <td style="display:flex; gap:6px; align-items:center;">
                        @if (user.Status == "Active")
                        {
                            <form method="post" action="/UserManagement/Disable" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <button type="submit" class="btn btn-disable">Disable</button>
                            </form>
                        }
                        else
                        {
                            <form method="post" action="/UserManagement/Enable" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.UserId" />
                                <button type="submit" class="btn btn-activate">Activate</button>
                            </form>
                        }

                        <form method="post" action="/UserManagement/Delete" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="userId" value="@user.UserId" />
                            <button type="submit" class="btn btn-delete"
                                    onclick="return confirm('Are you sure you want to delete this user?')">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }

            @if (!Model.Users.Any())
            {
                <tr>
                    <td colspan="6" style="text-align:center; padding:30px; color:#94a3b8;">No users found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
